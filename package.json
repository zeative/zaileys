{
  "name": "zaileys",
  "version": "0.28.93-beta",
  "description": "Zaileys - Simplify Typescript/Javascript WhatsApp NodeJS API",
  "keywords": [
    "zaileys",
    "whatsapp",
    "wa-simplify",
    "bot-zaileys",
    "whatsapp",
    "js-whatsapp",
    "whatsapp-chat",
    "whatsapp-api",
    "whatsapp-web",
    "whatsapp-group",
    "automation",
    "multi-device"
  ],
  "homepage": "https://github.com/zeative/zaileys",
  "repository": {
    "url": "git@github.com:zeative/zaileys.git"
  },
  "license": "MIT",
  "author": "zaadevofc",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "files": [
    "lib/*"
  ],
  "scripts": {
    "build:all": "tsc && typedoc",
    "build:docs": "typedoc",
    "build:tsc": "tsc",
    "changelog:last": "conventional-changelog -p angular -r 2",
    "changelog:preview": "conventional-changelog -p angular -u",
    "changelog:update": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0",
    "lint": "eslint src --ext .js,.ts",
    "lint:fix": "yarn lint --fix",
    "prepack": "tsc",
    "prepare": "tsc",
    "release": "release-it"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.12",
    "awesome-phonenumber": "^7.2.0",
    "consola": "^3.4.0",
    "global": "^4.4.0",
    "jimp": "0.22.12",
    "node-cache": "^5.1.2",
    "pino": "^9.6.0",
    "qrcode-terminal": "^0.12.0",
    "tsc": "^2.0.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^16.0.0",
    "ts-node": "^10.8.1",
    "ts-node-dev": "^2.0.0",
    "typedoc": "^0.24.7",
    "typescript": "^4.6.4"
  }
}
