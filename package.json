{
  "name": "zaileys",
  "description": "Zaileys - Simplified WhatsApp Node.js TypeScript/JavaScript API",
  "version": "3.3.0",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "author": "zaadevofc",
  "repository": {
    "url": "git+https://github.com/zeative/zaileys.git"
  },
  "keywords": [
    "baileys",
    "zaileys",
    "whatsapp",
    "whatsapp-api",
    "whatsapp-web",
    "whatsapp-bot",
    "multi-device",
    "simplified",
    "automation",
    "modern-library",
    "nodejs",
    "javascript-typescript"
  ],
  "scripts": {
    "dev": "tsx --watch examples/basic.ts",
    "build": "tsup",
    "changeset": "changeset",
    "release:version": "changeset version && pnpm install",
    "release:publish": "pnpm run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^24.10.1",
    "@types/qrcode-terminal": "^0.12.2",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@seald-io/nedb": "^4.1.2",
    "@zaileys/media-process": "workspace:*",
    "async-mutex": "^0.5.0",
    "audio-decode": "^2.2.3",
    "baileys": "^7.0.0-rc.9",
    "figlet": "^1.9.4",
    "gradient-string": "^3.0.0",
    "lru-cache": "^11.2.7",
    "nanospinner": "^1.2.2",
    "pino": "^10.1.0",
    "qrcode-terminal": "^0.12.0",
    "radashi": "^12.7.2",
    "valibot": "^1.2.0"
  },
  "optionalDependencies": {
    "lmdb": "^3.5.2"
  },
  "packageManager": "pnpm@10.24.0",
  "engines": {
    "node": ">=20.0.0"
  }
}