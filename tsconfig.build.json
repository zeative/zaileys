{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "incremental": false,
    "tsBuildInfoFile": null
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "scripts", "examples", ".session", ".temp", ".planning", "**/*.test.ts", "**/*.spec.ts"]
}
